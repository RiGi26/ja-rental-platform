# Supabase Core (Auth, Tenant, Billing)
NEXT_PUBLIC_SUPABASE_CORE_URL=https://your-core-project.supabase.co
NEXT_PUBLIC_SUPABASE_CORE_ANON_KEY=your-core-anon-key
SUPABASE_CORE_SERVICE_ROLE_KEY=your-core-service-role-key

# Supabase Rental (Vehicles, Routes, Schedules, Bookings)
NEXT_PUBLIC_SUPABASE_RENTAL_URL=https://your-rental-project.supabase.co
NEXT_PUBLIC_SUPABASE_RENTAL_ANON_KEY=your-rental-anon-key
SUPABASE_RENTAL_SERVICE_ROLE_KEY=your-rental-service-role-key

# Midtrans
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
MIDTRANS_IS_PRODUCTION=false

# WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=your-wa-token
WHATSAPP_PHONE_ID=your-phone-id

# Resend (email)
RESEND_API_KEY=re_xxxx
RESEND_FROM=noreply@japanarenacorp.com

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
